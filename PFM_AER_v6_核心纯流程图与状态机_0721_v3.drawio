        </mxCell>
        <mxCell id="p7___sub" value="cooldown_until/deadline_at 是绝对时间寄存器；因此没有新 pulse 时也会自然到期" style="whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;fontColor=#172033;fontSize=12;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" vertex="1" parent="1">
