        <mxCell id="p29_t3" parent="1" style="whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" value="t=3 第一个spike：count=1&lt;br&gt;first=last=3；P_HOLDOFF" vertex="1">
