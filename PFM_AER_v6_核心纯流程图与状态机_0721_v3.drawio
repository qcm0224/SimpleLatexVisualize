  <diagram id="page_06" name="06_ISIChangeDetector状态机">
    <mxGraphModel dx="1600" dy="1040" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1040" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p5___title" value="ISIChangeDetector：warmup、跟踪、单拍 hint 与滞回" style="whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontColor=#172033;fontSize=23;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="35" y="22" width="1210" height="58" as="geometry" />
        </mxCell>
        <mxCell id="p5___type" value="【状态机】&lt;br&gt;可选目标 RTL" style="whiteSpace=wrap;html=1;fillColor=#F3E8FF;strokeColor=#7E22CE;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;dashed=1;dashPattern=8 4;" vertex="1" parent="1">
          <mxGeometry x="1270" y="22" width="295" height="58" as="geometry" />
        </mxCell>
        <mxCell id="p5___sub" value="activity_hint 只能使已有 pending batch 提前 READY，不能屏蔽 accepted event" style="whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;fontColor=#172033;fontSize=12;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="55" y="88" width="1490" height="34" as="geometry" />
        </mxCell>
        <mxCell id="p5_reset" value="CH_RESET" style="whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=ellipse;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="55" y="220" width="170" height="75" as="geometry" />
        </mxCell>
        <mxCell id="p5_warm" value="CH_WARMUP&lt;br&gt;等待足够 ISI 样本" style="whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=ellipse;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="320" y="185" width="230" height="125" as="geometry" />
        </mxCell>
        <mxCell id="p5_track" value="CH_TRACK&lt;br&gt;更新 t_prev / isi_ref" style="whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=ellipse;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="690" y="185" width="230" height="125" as="geometry" />
        </mxCell>
        <mxCell id="p5_hint" value="CH_HINT&lt;br&gt;activity_hint=1 一周期" style="whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=ellipse;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1060" y="185" width="240" height="125" as="geometry" />
        </mxCell>
        <mxCell id="p5_error" value="CH_ERROR&lt;br&gt;时间倒序/差分溢出" style="whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=ellipse;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="710" y="700" width="240" height="115" as="geometry" />
        </mxCell>
        <mxCell id="p5_note" value="TH_HIGH &gt; TH_LOW 形成滞回。未收到 evt 时状态保持，不需要逐周期伪造 ISI。&lt;br&gt;时间倒序/差分溢出 -&gt; CH_ERROR；仅 system_reset 恢复。" style="whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;fontColor=#172033;fontSize=15;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="430" y="455" width="520" height="125" as="geometry" />
        </mxCell>
        <mxCell id="p5___footer" value="图例：椭圆=状态；箭头=条件/边沿动作；红色=错误；未画出的等待=default hold，精确优先级见CSV" style="whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;fontColor=#172033;fontSize=11;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="45" y="984" width="1510" height="32" as="geometry" />
        </mxCell>
        <mxCell id="p5_e0" value="system_reset 释放" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#1E3A5F;strokeWidth=1.8;dashed=0;endArrow=block;endFill=1;fontSize=13;fontColor=#172033;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="p5_reset" target="p5_warm">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p5_e1" value="accepted_evt &amp;&amp; samples&lt;W / 累积" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#1E3A5F;strokeWidth=1.8;dashed=0;endArrow=block;endFill=1;fontSize=13;fontColor=#172033;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="p5_warm" target="p5_warm">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p5_e2" value="accepted_evt &amp;&amp; samples==W" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#1E3A5F;strokeWidth=1.8;dashed=0;endArrow=block;endFill=1;fontSize=13;fontColor=#172033;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="p5_warm" target="p5_track">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p5_e3" value="accepted_evt &amp;&amp; diff&gt;=TH_HIGH" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#1E3A5F;strokeWidth=1.8;dashed=0;endArrow=block;endFill=1;fontSize=13;fontColor=#172033;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="p5_track" target="p5_hint">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p5_e4" value="无 evt 或 diff&lt;TH_HIGH / 正常更新" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#1E3A5F;strokeWidth=1.8;dashed=0;endArrow=block;endFill=1;fontSize=13;fontColor=#172033;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="p5_track" target="p5_track">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p5_e5" value="下一周期 / hint 清零" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#1E3A5F;strokeWidth=1.8;dashed=0;endArrow=block;endFill=1;fontSize=13;fontColor=#172033;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="p5_hint" target="p5_track">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="page_07" name="07_TimeBatch完整主流程">
    <mxGraphModel dx="1600" dy="1040" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1040" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
