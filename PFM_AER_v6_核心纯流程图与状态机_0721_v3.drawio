          <mxGeometry x="1270" y="22" width="295" height="58" as="geometry" />
        </mxCell>
        <mxCell id="p23___sub" value="每个 admitted tile 在一次 context 内最多真实 commit 一次；新 tile 不动态加入" style="whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;fontColor=#172033;fontSize=12;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="55" y="88" width="1490" height="34" as="geometry" />
        </mxCell>
        <mxCell id="p23_closed" value="R_CLOSED&lt;br&gt;无 prefix ownership" style="whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=ellipse;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="45" y="180" width="205" height="125" as="geometry" />
        </mxCell>
        <mxCell id="p23_start" value="R_START_PENDING&lt;br&gt;保持 START descriptor valid" style="whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=ellipse;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="175" width="230" height="135" as="geometry" />
        </mxCell>
        <mxCell id="p23_seed" value="R_SEED_PENDING&lt;br&gt;保持已 snapshot 的 seed descriptor" style="whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=ellipse;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="585" y="170" width="245" height="145" as="geometry" />
        </mxCell>
        <mxCell id="p23_select" value="R_SELECT&lt;br&gt;事务边界检查退出/候选" style="whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=ellipse;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="885" y="175" width="230" height="135" as="geometry" />
        </mxCell>
        <mxCell id="p23_local" value="R_LOCAL_SERVICE&lt;br&gt;内部含 OFFER/BUSY&lt;br&gt;owner=REGION" style="whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=ellipse;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1175" y="170" width="245" height="145" as="geometry" />
