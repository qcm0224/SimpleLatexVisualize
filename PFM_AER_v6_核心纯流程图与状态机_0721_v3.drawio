  <diagram id="page_22" name="22_Morton地址与固定Region前缀">
    <mxGraphModel dx="2054" dy="1184" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1040" background="#FFFFFF" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p21___title" parent="1" style="whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontColor=#172033;fontSize=23;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" value="Morton/Z-order：把真实 tile 坐标变成 region prefix + tile suffix" vertex="1">
          <mxGeometry height="58" width="1210" x="35" y="22" as="geometry" />
        </mxCell>
        <mxCell id="p21___type" parent="1" style="whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" value="【流程图】&lt;br&gt;空间编码；不参与 grant" vertex="1">
          <mxGeometry height="58" width="295" x="1270" y="22" as="geometry" />
        </mxCell>
        <mxCell id="p21___sub" parent="1" style="whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;fontColor=#172033;fontSize=12;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" value="4x4 tile grid 时 leaf={ty1,tx1,ty0,tx0}；这里只支持固定 2x2 region，不是多尺度前缀树" vertex="1">
          <mxGeometry height="34" width="1490" x="55" y="88" as="geometry" />
        </mxCell>
        <mxCell id="p21_start" parent="1" style="whiteSpace=wrap;html=1;fillColor=#CCFBF1;strokeColor=#0F766E;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=ellipse;fontStyle=1;" value="开始：真实 tile 坐标 (ty,tx)" vertex="1">
          <mxGeometry height="72" width="250" x="60" y="185" as="geometry" />
        </mxCell>
        <mxCell id="p21_valid" parent="1" style="whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=rhombus;perimeter=rhombusPerimeter;rounded=0;" value="坐标在有效 tile grid 内？" vertex="1">
          <mxGeometry height="110" width="245" x="360" y="166" as="geometry" />
        </mxCell>
        <mxCell id="p21_split" parent="1" style="whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" value="拆 ty/tx bit 并交织&lt;br&gt;leaf={ty1,tx1,ty0,tx0}" vertex="1">
          <mxGeometry height="100" width="260" x="720" y="171" as="geometry" />
        </mxCell>
        <mxCell id="p21_region" parent="1" style="whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=rhombus;perimeter=rhombusPerimeter;rounded=0;" value="当前 frame 在 region context 内？" vertex="1">
          <mxGeometry height="115" width="270" x="1020" y="165" as="geometry" />
        </mxCell>
        <mxCell id="p21_full" parent="1" style="whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" value="standalone：发送完整 Morton leaf" vertex="1">
          <mxGeometry height="90" width="250" x="1340" y="176" as="geometry" />
        </mxCell>
        <mxCell id="p21_suffix" parent="1" style="whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" value="region：prefix={ty1,tx1}&lt;br&gt;只发送 suffix={ty0,tx0}" vertex="1">
          <mxGeometry height="100" width="280" x="1015" y="405" as="geometry" />
        </mxCell>
        <mxCell id="p21_decode" parent="1" style="whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" value="Decoder 拼 prefix+suffix&lt;br&gt;再 deinterleave 得 (ty,tx)" vertex="1">
