        <mxCell id="p4___title" parent="1" style="whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontColor=#172033;fontSize=23;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" value="由 PFM 发放间隔检测光强变化：只提前 eligible，不门控计数" vertex="1">
          <mxGeometry height="58" width="1210" x="35" y="22" as="geometry" />
