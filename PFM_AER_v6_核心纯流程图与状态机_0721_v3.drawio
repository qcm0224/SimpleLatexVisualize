        </mxCell>
        <mxCell id="p7_ready" value="P_READY&lt;br&gt;eligible=1, urgent=0" style="whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=ellipse;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="970" y="175" width="240" height="130" as="geometry" />
