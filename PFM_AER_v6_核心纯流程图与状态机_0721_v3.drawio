        <mxCell id="p27_e3" edge="1" parent="1" source="p27_send" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#1E3A5F;strokeWidth=1.8;dashed=0;endArrow=block;endFill=1;fontSize=13;fontColor=#172033;labelBackgroundColor=#FFFFFF;" target="p27_last" value="next beat is final">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p27_e4" edge="1" parent="1" source="p27_last" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#1E3A5F;strokeWidth=1.8;dashed=0;endArrow=block;endFill=1;fontSize=13;fontColor=#172033;labelBackgroundColor=#FFFFFF;" target="p27_last" value="!tx_ready / 保持">
          <mxGeometry relative="1" as="geometry" />
