  <diagram id="page_16" name="16_TileService状态机">
    <mxGraphModel dx="1600" dy="1040" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1040" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p15___title" value="TileService：四相 Req/Ack 只负责原子 snapshot，不串行等待 wire" style="whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontColor=#172033;fontSize=23;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="35" y="22" width="1210" height="58" as="geometry" />
        </mxCell>
        <mxCell id="p15___type" value="【状态机】&lt;br&gt;核心目标 RTL" style="whiteSpace=wrap;html=1;fillColor=#F3E8FF;strokeColor=#7E22CE;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;dashed=1;dashPattern=8 4;" vertex="1" parent="1">
          <mxGeometry x="1270" y="22" width="295" height="58" as="geometry" />
        </mxCell>
        <mxCell id="p15___sub" value="成功边沿优先于同拍 timeout；snapshot_commit 只在 TS_COMMIT 产生一次" style="whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;fontColor=#172033;fontSize=12;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="55" y="88" width="1490" height="34" as="geometry" />
        </mxCell>
        <mxCell id="p15_idle" value="TS_IDLE&lt;br&gt;等待 frozen offer+resv" style="whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=ellipse;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="55" y="190" width="220" height="120" as="geometry" />
        </mxCell>
        <mxCell id="p15_req" value="TS_REQ_HIGH&lt;br&gt;svc_req=1；字段保持" style="whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=ellipse;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="360" y="185" width="230" height="130" as="geometry" />
        </mxCell>
        <mxCell id="p15_commit" value="TS_COMMIT&lt;br&gt;pulse snapshot_commit=1" style="whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=ellipse;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="700" y="185" width="235" height="130" as="geometry" />
        </mxCell>
        <mxCell id="p15_zero" value="TS_RETURN_ZERO&lt;br&gt;svc_req=0；等待 svc_ack=0" style="whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=ellipse;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1040" y="180" width="260" height="140" as="geometry" />
        </mxCell>
        <mxCell id="p15_done" value="TS_DONE&lt;br&gt;pulse service_done" style="whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=ellipse;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1320" y="420" width="220" height="120" as="geometry" />
        </mxCell>
        <mxCell id="p15_error" value="TS_ERROR&lt;br&gt;游离 ACK / tag mismatch / timeout" style="whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=ellipse;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="710" y="735" width="290" height="115" as="geometry" />
        </mxCell>
        <mxCell id="p15_note" value="边界定义：若 svc_ack 在 deadline 周期为 1，则按成功处理；只有 timeout &amp;&amp; !svc_ack 才报错。&lt;br&gt;游离 ACK、tag mismatch 或 timeout -&gt; TS_ERROR；仅 reset 恢复。" style="whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;fontColor=#172033;fontSize=15;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="220" y="485" width="590" height="140" as="geometry" />
        </mxCell>
        <mxCell id="p15___footer" value="图例：椭圆=状态；箭头=条件/边沿动作；红色=错误；未画出的等待=default hold，精确优先级见CSV" style="whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;fontColor=#172033;fontSize=11;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="45" y="984" width="1510" height="32" as="geometry" />
        </mxCell>
        <mxCell id="p15_e0" value="start_service &amp;&amp; reservation_valid" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#1E3A5F;strokeWidth=1.8;dashed=0;endArrow=block;endFill=1;fontSize=13;fontColor=#172033;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="p15_idle" target="p15_req">
          <mxGeometry relative="1" as="geometry" />
