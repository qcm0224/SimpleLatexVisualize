        <mxCell id="p2_over" parent="1" style="whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" value="置 capture_loss_sticky&lt;br&gt;若前端支持计数则 capture_drop++" vertex="1">
