        <mxCell id="p29___title" parent="1" style="whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontColor=#172033;fontSize=23;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" value="16x16 / 4x4-pixel tile：同一 pixel 的 5 颗 pulse 怎样合成一个 batch" vertex="1">
          <mxGeometry height="58" width="1210" x="35" y="22" as="geometry" />
        </mxCell>
        <mxCell id="p29___type" parent="1" style="whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" value="【流程图】&lt;br&gt;具体周期例；参数仅示范" vertex="1">
          <mxGeometry height="58" width="295" x="1270" y="22" as="geometry" />
