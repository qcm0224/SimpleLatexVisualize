          <mxGeometry height="58" width="295" x="1270" y="22" as="geometry" />
        </mxCell>
        <mxCell id="p4___sub" parent="1" style="whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;fontColor=#172033;fontSize=12;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" value="逻辑按 pixel 保存 t_prev 与 isi_ref；物理上建议放 tile 边缘" vertex="1">
