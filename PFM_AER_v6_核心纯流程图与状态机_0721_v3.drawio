        </mxCell>
        <mxCell id="p12_retry" parent="1" style="whiteSpace=wrap;html=1;fillColor=#CCFBF1;strokeColor=#0F766E;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=ellipse;fontStyle=1;" value="结束：reserve_reject&lt;br&gt;不冻结、不更新 RR" vertex="1">
