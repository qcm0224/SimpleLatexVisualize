        </mxCell>
        <mxCell id="p24_done" value="结束：释放 ownership&lt;br&gt;进入 reentry guard" style="whiteSpace=wrap;html=1;fillColor=#CCFBF1;strokeColor=#0F766E;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=ellipse;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="365" y="590" width="260" height="82" as="geometry" />
        </mxCell>
