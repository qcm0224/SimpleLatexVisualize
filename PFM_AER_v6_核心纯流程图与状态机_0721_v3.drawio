        <mxCell id="p15_e1" value="svc_ack &amp;&amp; matching_tag / success wins" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#1E3A5F;strokeWidth=1.8;dashed=0;endArrow=block;endFill=1;fontSize=13;fontColor=#172033;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="p15_req" target="p15_commit">
