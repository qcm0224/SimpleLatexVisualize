        <mxCell id="p27___title" parent="1" style="whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontColor=#172033;fontSize=23;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" value="Serializer：装载 packet、背压保持、最后一拍 fire 后唯一 pop" vertex="1">
          <mxGeometry height="58" width="1210" x="35" y="22" as="geometry" />
        </mxCell>
        <mxCell id="p27___type" parent="1" style="whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" value="【状态机】&lt;br&gt;单向 valid/ready 链路" vertex="1">
          <mxGeometry height="58" width="295" x="1270" y="22" as="geometry" />
        </mxCell>
        <mxCell id="p27___sub" parent="1" style="whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;fontColor=#172033;fontSize=12;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" value="没有 WAIT_REMOTE_ACK / receiver commit replay；若将来需要，必须另立反向协议" vertex="1">
          <mxGeometry height="34" width="1490" x="55" y="88" as="geometry" />
        </mxCell>
        <mxCell id="p27_idle" parent="1" style="whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=ellipse;fontStyle=1;" value="SER_IDLE&lt;br&gt;等待 packet FIFO" vertex="1">
          <mxGeometry height="120" width="220" x="90" y="270" as="geometry" />
        </mxCell>
        <mxCell id="p27_load" parent="1" style="whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=ellipse;fontStyle=1;" value="SER_LOAD&lt;br&gt;锁 packet entry/length/tag" vertex="1">
          <mxGeometry height="130" width="235" x="430" y="175" as="geometry" />
        </mxCell>
        <mxCell id="p27_send" parent="1" style="whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=ellipse;fontStyle=1;" value="SER_SEND&lt;br&gt;tx_valid=1；保持当前 beat" vertex="1">
          <mxGeometry height="135" width="250" x="820" y="170" as="geometry" />
        </mxCell>
        <mxCell id="p27_last" parent="1" style="whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=ellipse;fontStyle=1;" value="SER_LAST&lt;br&gt;最后 beat + last_valid_bits" vertex="1">
          <mxGeometry height="135" width="260" x="1270" y="255" as="geometry" />
        </mxCell>
        <mxCell id="p27_done" parent="1" style="whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=ellipse;fontStyle=1;" value="SER_DONE&lt;br&gt;pop packet；pulse wire_done" vertex="1">
          <mxGeometry height="130" width="240" x="1510" y="487.5" as="geometry" />
        </mxCell>
        <mxCell id="p27_note" parent="1" style="whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;fontColor=#172033;fontSize=15;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" value="tx_valid &amp;&amp; !tx_ready 时 beat、last、last_valid_bits、tag 全部稳定。进入 SER_LAST 不等于已发送；必须等待 fire。&lt;br&gt;bad length/FIFO underrun/local link fault -&gt; SER_ERROR；仅 reset 恢复。" vertex="1">
          <mxGeometry height="145" width="570" x="110" y="480" as="geometry" />
        </mxCell>
        <mxCell id="p27___footer" parent="1" style="whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;fontColor=#172033;fontSize=11;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" value="图例：椭圆=状态；箭头=条件/边沿动作；红色=错误；未画出的等待=default hold，精确优先级见CSV" vertex="1">
          <mxGeometry height="32" width="1510" x="45" y="984" as="geometry" />
        </mxCell>
        <mxCell id="p27_e0" edge="1" parent="1" source="p27_idle" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#1E3A5F;strokeWidth=1.8;dashed=0;endArrow=block;endFill=1;fontSize=13;fontColor=#172033;labelBackgroundColor=#FFFFFF;" target="p27_load" value="packet_valid &amp;&amp; packet_ready">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p27_e1" edge="1" parent="1" source="p27_load" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#1E3A5F;strokeWidth=1.8;dashed=0;endArrow=block;endFill=1;fontSize=13;fontColor=#172033;labelBackgroundColor=#FFFFFF;" target="p27_send" value="entry_loaded">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p27_e2" edge="1" parent="1" source="p27_send" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#1E3A5F;strokeWidth=1.8;dashed=0;endArrow=block;endFill=1;fontSize=13;fontColor=#172033;labelBackgroundColor=#FFFFFF;" target="p27_send" value="!tx_ready 或 非最后 beat / 保持或推进">
          <mxGeometry relative="1" as="geometry" />
