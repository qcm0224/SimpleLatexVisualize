        </mxCell>
        <mxCell id="p29_clear" parent="1" style="whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" value="active 清空；cooldown_until=17&lt;br&gt;同 tile 未冻结邻居保持不变" vertex="1">
