        <mxCell id="p23_end" value="R_END_PENDING&lt;br&gt;保持 END descriptor valid" style="whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=ellipse;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1305" y="500" width="240" height="135" as="geometry" />
        </mxCell>
        <mxCell id="p23_guard" value="R_REENTRY_GUARD&lt;br&gt;ownership=0；阻止同 prefix 立即重开" style="whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=ellipse;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="850" y="720" width="290" height="140" as="geometry" />
        </mxCell>
        <mxCell id="p23_error" value="R_ERROR&lt;br&gt;duplicate/tag/quota/END credit fault" style="whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=ellipse;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="380" y="740" width="300" height="120" as="geometry" />
        </mxCell>
        <mxCell id="p23_note" value="退出优先级：outside urgent &gt; absolute timeout &gt; payload quota &gt; tile quota &gt; exhausted。served 只在 matching snapshot_commit 上升。&lt;br&gt;duplicate/tag/quota/END credit 错误 -&gt; R_ERROR；仅 reset 恢复。" style="whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;fontColor=#172033;fontSize=15;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="480" width="600" height="150" as="geometry" />
        </mxCell>
        <mxCell id="p23___footer" value="图例：椭圆=状态；箭头=条件/边沿动作；红色=错误；未画出的等待=default hold，精确优先级见CSV" style="whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;fontColor=#172033;fontSize=11;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="45" y="984" width="1510" height="32" as="geometry" />
        </mxCell>
        <mxCell id="p23_e0" value="promotion_accept" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#1E3A5F;strokeWidth=1.8;dashed=0;endArrow=block;endFill=1;fontSize=13;fontColor=#172033;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="p23_closed" target="p23_start">
