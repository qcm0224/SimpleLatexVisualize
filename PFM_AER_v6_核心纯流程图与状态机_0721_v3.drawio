        </mxCell>
        <mxCell id="p25___sub" parent="1" style="whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;fontColor=#172033;fontSize=12;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" value="接收端不返回 commit ACK；本地 packet FIFO 的 ready/valid 提供唯一背压" vertex="1">
          <mxGeometry height="34" width="1490" x="55" y="88" as="geometry" />
        </mxCell>
        <mxCell id="p25_start" parent="1" style="whiteSpace=wrap;html=1;fillColor=#CCFBF1;strokeColor=#0F766E;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=ellipse;fontStyle=1;" value="开始：有 data/control descriptor" vertex="1">
          <mxGeometry height="72" width="270" x="55" y="180" as="geometry" />
        </mxCell>
