  <diagram id="page_04" name="04_PulseCatcherCDC状态机">
    <mxGraphModel dx="1600" dy="1040" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1040" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p3___title" value="PulseCatcherCDC：pending token、同步确认、背压与重新 armed" style="whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontColor=#172033;fontSize=23;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="35" y="22" width="1210" height="58" as="geometry" />
        </mxCell>
        <mxCell id="p3___type" value="【状态机】&lt;br&gt;目标 GALS；概念 FSM" style="whiteSpace=wrap;html=1;fillColor=#F3E8FF;strokeColor=#7E22CE;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;dashed=1;dashPattern=8 4;" vertex="1" parent="1">
          <mxGeometry x="1270" y="22" width="295" height="58" as="geometry" />
        </mxCell>
        <mxCell id="p3___sub" value="异步置位单元、CDC 与亚稳态必须由目标 PDK 单独验证" style="whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;fontColor=#172033;fontSize=12;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="55" y="88" width="1490" height="34" as="geometry" />
        </mxCell>
        <mxCell id="p3_reset" value="PC_RESET" style="whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=ellipse;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="45" y="220" width="170" height="75" as="geometry" />
        </mxCell>
        <mxCell id="p3_armed" value="PC_ARMED&lt;br&gt;等待 spike" style="whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=ellipse;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="190" width="220" height="120" as="geometry" />
        </mxCell>
        <mxCell id="p3_latched" value="PC_LATCHED&lt;br&gt;pending=1；锁 t_capture" style="whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=ellipse;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="640" y="185" width="250" height="130" as="geometry" />
        </mxCell>
        <mxCell id="p3_offer" value="PC_OFFER&lt;br&gt;evt_valid=1；payload稳定" style="whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=ellipse;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1020" y="185" width="250" height="130" as="geometry" />
        </mxCell>
        <mxCell id="p3_rearm" value="PC_REARM&lt;br&gt;清异步锁存并等回零" style="whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=ellipse;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1300" y="400" width="235" height="125" as="geometry" />
        </mxCell>
        <mxCell id="p3_error" value="PC_ERROR&lt;br&gt;CDC/协议不变量失败" style="whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=ellipse;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="690" y="745" width="250" height="115" as="geometry" />
        </mxCell>
        <mxCell id="p3_note" value="evt_valid &amp;&amp; !evt_ready 时必须保持 t_capture/pixel identity。busy 期间额外 spike 只置 loss；不能覆盖 pending token。&lt;br&gt;任意 CDC/时间戳/背压不变量失败 -&gt; PC_ERROR；仅 system_reset 恢复。" style="whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;fontColor=#172033;fontSize=15;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="210" y="500" width="600" height="130" as="geometry" />
        </mxCell>
        <mxCell id="p3___footer" value="图例：椭圆=状态；箭头=条件/边沿动作；红色=错误；未画出的等待=default hold，精确优先级见CSV" style="whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;fontColor=#172033;fontSize=11;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="45" y="984" width="1510" height="32" as="geometry" />
        </mxCell>
        <mxCell id="p3_e0" value="system_reset 释放" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#1E3A5F;strokeWidth=1.8;dashed=0;endArrow=block;endFill=1;fontSize=13;fontColor=#172033;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="p3_reset" target="p3_armed">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p3_e1" value="async_spike / latch t_capture" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#1E3A5F;strokeWidth=1.8;dashed=0;endArrow=block;endFill=1;fontSize=13;fontColor=#172033;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="p3_armed" target="p3_latched">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p3_e2" value="sync_seen" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#1E3A5F;strokeWidth=1.8;dashed=0;endArrow=block;endFill=1;fontSize=13;fontColor=#172033;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="p3_latched" target="p3_offer">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
