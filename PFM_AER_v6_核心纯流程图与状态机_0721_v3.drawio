          <mxGeometry x="60" y="185" width="220" height="72" as="geometry" />
        </mxCell>
        <mxCell id="p13_bank" value="free snapshot bank &gt;=1？" style="whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=rhombus;perimeter=rhombusPerimeter;rounded=0;" vertex="1" parent="1">
