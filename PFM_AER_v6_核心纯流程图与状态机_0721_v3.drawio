        </mxCell>
        <mxCell id="p7_error" value="P_ERROR&lt;br&gt;非法 commit / 不变量失败" style="whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=ellipse;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1070" y="745" width="280" height="115" as="geometry" />
        </mxCell>
        <mxCell id="p7_note" value="统一优先级：reset -&gt; fatal -&gt; 形成 post-event -&gt; matching commit 消费 post-event -&gt; hard urgent -&gt; ready -&gt; hold。&lt;br&gt;同拍 accepted_evt 进入旧 snapshot；非法 commit/不变量失败 -&gt; P_ERROR，仅 reset 恢复。" style="whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;fontColor=#172033;fontSize=15;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" vertex="1" parent="1">
