        <mxCell id="p2_accept" parent="1" style="whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=rhombus;perimeter=rhombusPerimeter;rounded=0;" value="下游接受 evt packet？" vertex="1">
          <mxGeometry height="105" width="225" x="1185" y="545" as="geometry" />
