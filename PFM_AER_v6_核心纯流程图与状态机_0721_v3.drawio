        </mxCell>
        <mxCell id="p4_start" parent="1" style="whiteSpace=wrap;html=1;fillColor=#CCFBF1;strokeColor=#0F766E;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=ellipse;fontStyle=1;" value="开始：收到 accepted evt&lt;br&gt;时间为 t_capture" vertex="1">
          <mxGeometry height="82" width="230" x="60" y="185" as="geometry" />
        </mxCell>
        <mxCell id="p4_prev" parent="1" style="whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=rhombus;perimeter=rhombusPerimeter;rounded=0;" value="已有上一个时间戳？" vertex="1">
          <mxGeometry height="110" width="230" x="360" y="170" as="geometry" />
        </mxCell>
        <mxCell id="p4_init" parent="1" style="whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" value="保存 t_prev=t_capture&lt;br&gt;初始化 warmup；hint=0" vertex="1">
          <mxGeometry height="92" width="230" x="360" y="385" as="geometry" />
        </mxCell>
        <mxCell id="p4_isi" parent="1" style="whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" value="计算 isi= t_capture - t_prev&lt;br&gt;diff=|isi-isi_ref|" vertex="1">
          <mxGeometry height="100" width="240" x="670" y="176" as="geometry" />
        </mxCell>
        <mxCell id="p4_high" parent="1" style="whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=rhombus;perimeter=rhombusPerimeter;rounded=0;" value="diff &gt;= TH_HIGH？" vertex="1">
          <mxGeometry height="110" width="225" x="970" y="171" as="geometry" />
        </mxCell>
        <mxCell id="p4_hint" parent="1" style="whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" value="activity_hint=1 一个周期&lt;br&gt;PixelBatch 会把 pending 锁成 READY" vertex="1">
          <mxGeometry height="120" width="245" x="1390" y="276" as="geometry" />
        </mxCell>
        <mxCell id="p4_low" parent="1" style="whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=rhombus;perimeter=rhombusPerimeter;rounded=0;" value="diff &lt;= TH_LOW？" vertex="1">
          <mxGeometry height="110" width="225" x="750" y="376" as="geometry" />
        </mxCell>
        <mxCell id="p4_keep" parent="1" style="whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" value="保持上一次 change 状态&lt;br&gt;避免阈值附近抖动" vertex="1">
