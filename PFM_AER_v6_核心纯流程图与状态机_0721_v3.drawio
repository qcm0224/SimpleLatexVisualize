        <mxCell id="p12_return" parent="1" style="whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" value="svc_req 拉低并等 svc_ack=0&lt;br&gt;TileService 完成；不等 wire ACK" vertex="1">
