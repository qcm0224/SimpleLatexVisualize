        <mxCell id="p29_snap" parent="1" style="whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" value="是：先 ingest，再 snapshot&lt;br&gt;输出 count=5, first=3,last=9" vertex="1">
