        </mxCell>
        <mxCell id="p24_none" value="存在 eligible remaining tile？" style="whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=rhombus;perimeter=rhombusPerimeter;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="1100" y="160" width="260" height="120" as="geometry" />
