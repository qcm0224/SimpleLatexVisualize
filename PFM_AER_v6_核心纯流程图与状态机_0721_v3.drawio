        <mxCell id="p2_rearm" parent="1" style="whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" value="清 pending_event&lt;br&gt;catcher状态恢复进入下一循环" vertex="1">
          <mxGeometry height="85" width="210" x="910" y="555" as="geometry" />
        </mxCell>
        <mxCell id="p2_hold" parent="1" style="whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" value="保持 pending 与时间戳稳定&lt;br&gt;不得覆盖旧 evt packet" vertex="1">
