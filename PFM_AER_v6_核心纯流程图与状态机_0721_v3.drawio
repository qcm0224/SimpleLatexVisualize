        <mxCell id="p29_t7" parent="1" style="whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" value="t=7和8 产生脉冲：count=4&lt;br&gt;命中 COUNT_TH -&amp;gt; READY" vertex="1">
