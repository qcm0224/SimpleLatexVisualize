        <mxCell id="p29_t5" parent="1" style="whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" value="t=5 spike：count=2,last=5&lt;br&gt;仍未到阈值holdoff" vertex="1">
