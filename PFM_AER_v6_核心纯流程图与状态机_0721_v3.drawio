        <mxCell id="p19_free" value="SEG_FREE" style="whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=ellipse;fontStyle=1;" vertex="1" parent="1">
