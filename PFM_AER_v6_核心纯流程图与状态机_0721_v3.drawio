        <mxCell id="p14_encode" value="RS_ENCODING&lt;br&gt;Encoder/slots 接管 records" style="whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=ellipse;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1080" y="180" width="250" height="130" as="geometry" />
        </mxCell>
        <mxCell id="p14_packet" value="RS_PACKET_OWNED&lt;br&gt;完整 frame 等待入 packet FIFO" style="whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=ellipse;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1285" y="500" width="275" height="135" as="geometry" />
        </mxCell>
        <mxCell id="p14_release" value="RS_RELEASE&lt;br&gt;一次性返还 bank/desc/slots" style="whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=ellipse;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="880" y="710" width="270" height="120" as="geometry" />
        </mxCell>
        <mxCell id="p14_error" value="RS_ERROR&lt;br&gt;重复释放/错误 tag/状态越级" style="whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=ellipse;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="390" y="740" width="290" height="115" as="geometry" />
        </mxCell>
        <mxCell id="p14_note" value="timestamp segment 不属于本 entry 的 free bitmap；它由第20页独立 owner 管理。控制 frame has_bank=0。&lt;br&gt;重复释放、错误 tag 或状态越级 -&gt; RS_ERROR；仅 reset 恢复。" style="whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;fontColor=#172033;fontSize=15;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" vertex="1" parent="1">
