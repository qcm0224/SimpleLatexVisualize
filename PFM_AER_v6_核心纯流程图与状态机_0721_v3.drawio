        </mxCell>
        <mxCell id="p19_note" value="allocation 或 write 失败时，PixelBatch 保留 count 并置 TIMESTAMP_LOSS。已分配 segment 仍只释放一次。&lt;br&gt;wrong owner、seal 后写入或重复释放 -&gt; SEG_ERROR；仅 reset 恢复。" style="whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;fontColor=#172033;fontSize=15;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" vertex="1" parent="1">
