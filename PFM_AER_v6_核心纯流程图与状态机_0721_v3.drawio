  <diagram id="page_12" name="12_TwoDArbiter状态机">
    <mxGraphModel dx="1600" dy="1040" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1040" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p11___title" value="TwoDArbiter：tentative offer、资源接受、冻结 path 与 commit-only RR 更新" style="whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontColor=#172033;fontSize=23;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="35" y="22" width="1210" height="58" as="geometry" />
        </mxCell>
        <mxCell id="p11___type" value="【状态机】&lt;br&gt;核心目标 RTL" style="whiteSpace=wrap;html=1;fillColor=#F3E8FF;strokeColor=#7E22CE;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;dashed=1;dashPattern=8 4;" vertex="1" parent="1">
          <mxGeometry x="1270" y="22" width="295" height="58" as="geometry" />
        </mxCell>
        <mxCell id="p11___sub" value="ResourceManager 拒绝只导致重试；只有完整 tag 匹配的 snapshot_commit 才更新公平状态" style="whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;fontColor=#172033;fontSize=12;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="55" y="88" width="1490" height="34" as="geometry" />
        </mxCell>
        <mxCell id="p11_idle" value="A_IDLE&lt;br&gt;等事务边界" style="whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=ellipse;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="55" y="185" width="210" height="120" as="geometry" />
        </mxCell>
        <mxCell id="p11_row" value="A_ROW&lt;br&gt;选择真实非空 ty" style="whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=ellipse;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="345" y="180" width="225" height="125" as="geometry" />
        </mxCell>
        <mxCell id="p11_col" value="A_COL&lt;br&gt;只从 row ty 选 tx" style="whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=ellipse;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="650" y="180" width="225" height="125" as="geometry" />
        </mxCell>
        <mxCell id="p11_offer" value="A_OFFER&lt;br&gt;保持 tentative pair/mask/path" style="whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=ellipse;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="955" y="175" width="250" height="135" as="geometry" />
        </mxCell>
        <mxCell id="p11_hold" value="A_HOLD&lt;br&gt;冻结 pair/mask/path/resv/tag" style="whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=ellipse;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1285" y="175" width="255" height="135" as="geometry" />
        </mxCell>
        <mxCell id="p11_commit" value="A_COMMIT&lt;br&gt;按 frozen path 更新 row RR&lt;br&gt;ptr_bank[ty]=tx+1" style="whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=ellipse;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="955" y="560" width="275" height="140" as="geometry" />
        </mxCell>
        <mxCell id="p11_error" value="A_ERROR&lt;br&gt;pair/index/tag invariant fail" style="whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;shape=ellipse;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="500" y="745" width="280" height="115" as="geometry" />
        </mxCell>
        <mxCell id="p11_note" value="A_OFFER 不占用资源；reserve_accept 才由 ResourceManager 原子分配并把 resv_id 交回。&lt;br&gt;reserve_reject、svc_ack、wire 完成都不更新 RR。pair/index/tag 错误 -&gt; A_ERROR；仅 reset 恢复。" style="whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;fontColor=#172033;fontSize=15;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="150" y="485" width="600" height="140" as="geometry" />
        </mxCell>
        <mxCell id="p11___footer" value="图例：椭圆=状态；箭头=条件/边沿动作；红色=错误；未画出的等待=default hold，精确优先级见CSV" style="whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;fontColor=#172033;fontSize=11;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="45" y="984" width="1510" height="32" as="geometry" />
        </mxCell>
        <mxCell id="p11_e0" value="transaction_boundary &amp;&amp; request_nonempty" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#1E3A5F;strokeWidth=1.8;dashed=0;endArrow=block;endFill=1;fontSize=13;fontColor=#172033;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="p11_idle" target="p11_row">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p11_e1" value="row_req==0" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#1E3A5F;strokeWidth=1.8;dashed=0;endArrow=block;endFill=1;fontSize=13;fontColor=#172033;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="p11_row" target="p11_idle">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="458" y="365" />
              <mxPoint x="160" y="365" />
            </Array>
          </mxGeometry>
