        <mxCell id="p25___title" parent="1" style="whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontColor=#172033;fontSize=23;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;" value="Snapshot descriptor -&gt; TemporalEncoder -&gt; PacketBuilder -&gt; FIFO -&gt; Serializer" vertex="1">
          <mxGeometry height="58" width="1210" x="35" y="22" as="geometry" />
        </mxCell>
        <mxCell id="p25___type" parent="1" style="whiteSpace=wrap;html=1;fillColor=#F3E8FF;strokeColor=#7E22CE;fontColor=#172033;fontSize=14;fontFamily=Arial;align=center;verticalAlign=middle;spacing=6;strokeWidth=1.8;rounded=1;dashed=1;dashPattern=8 4;" value="【流程图】&lt;br&gt;目标输出数据面" vertex="1">
